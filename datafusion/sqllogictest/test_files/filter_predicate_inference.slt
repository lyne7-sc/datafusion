statement ok
set datafusion.optimizer.enable_filter_predicate_inference = true;

statement ok
create table t(a int, b int) as values (1, 1), (11, 11), (12, 12);

statement ok
create table t4(a int, b int, c int, d int) as values
  (1, 1, 1, 1),
  (6, 6, 6, 101),
  (7, 7, 7, 102);

statement ok
COPY t TO 'test_files/scratch/filter_predicate_inference/t.parquet' STORED AS PARQUET;

statement ok
CREATE EXTERNAL TABLE tp(a int, b int)
STORED AS PARQUET
LOCATION 'test_files/scratch/filter_predicate_inference/t.parquet';

query TT
EXPLAIN FORMAT INDENT SELECT b FROM t WHERE a = b AND b > 10;
----
logical_plan
01)Projection: t.b
02)--Filter: t.b = t.a AND t.b > Int32(10)
03)----TableScan: t projection=[a, b]
physical_plan
01)FilterExec: b@1 = a@0 AND b@1 > 10 AND a@0 >= 11 AND b@1 >= 11, projection=[b@1]
02)--DataSourceExec: partitions=1, partition_sizes=[1]

# Literal equality should tighten both sides of an equality chain.
query TT
EXPLAIN FORMAT INDENT SELECT * FROM t WHERE 5 = a AND a = b;
----
logical_plan
01)Filter: t.a = Int32(5) AND t.b = t.a
02)--TableScan: t projection=[a, b]
physical_plan
01)FilterExec: a@0 = 5 AND b@1 = a@0 AND b@1 = 5
02)--DataSourceExec: partitions=1, partition_sizes=[1]

# Two-sided ranges should emit both lower and upper bounds.
query TT
EXPLAIN FORMAT INDENT SELECT * FROM t WHERE a = b AND b > 5 AND b < 10;
----
logical_plan
01)Filter: t.b = t.a AND t.b > Int32(5) AND t.b < Int32(10)
02)--TableScan: t projection=[a, b]
physical_plan
01)FilterExec: b@1 = a@0 AND b@1 > 5 AND b@1 < 10 AND a@0 >= 6 AND a@0 <= 9 AND b@1 >= 6 AND b@1 <= 9
02)--DataSourceExec: partitions=1, partition_sizes=[1]

# BETWEEN is planned as lower/upper comparisons and should infer bounds across equality.
query TT
EXPLAIN FORMAT INDENT SELECT * FROM t WHERE a = b AND b BETWEEN 5 AND 10;
----
logical_plan
01)Filter: t.b = t.a AND t.b >= Int32(5) AND t.b <= Int32(10)
02)--TableScan: t projection=[a, b]
physical_plan
01)FilterExec: b@1 = a@0 AND b@1 >= 5 AND b@1 <= 10 AND a@0 >= 5 AND a@0 <= 10
02)--DataSourceExec: partitions=1, partition_sizes=[1]

# Independent equality components should be inferred independently.
query TT
EXPLAIN FORMAT INDENT SELECT * FROM t4 WHERE a = b AND c = d AND d > 100;
----
logical_plan
01)Filter: t4.b = t4.a AND t4.d = t4.c AND t4.d > Int32(100)
02)--TableScan: t4 projection=[a, b, c, d]
physical_plan
01)FilterExec: b@1 = a@0 AND d@3 = c@2 AND d@3 > 100 AND c@2 >= 101 AND d@3 >= 101
02)--DataSourceExec: partitions=1, partition_sizes=[1]

# Equality chains should propagate a bound through all linked columns
# regardless of predicate order.
query TT
EXPLAIN FORMAT INDENT SELECT * FROM t4 WHERE a = b AND b = c AND a > 5;
----
logical_plan
01)Filter: t4.b = t4.a AND t4.c = t4.b AND t4.a > Int32(5)
02)--TableScan: t4 projection=[a, b, c, d]
physical_plan
01)FilterExec: b@1 = a@0 AND c@2 = b@1 AND a@0 > 5 AND a@0 >= 6 AND b@1 >= 6 AND c@2 >= 6
02)--DataSourceExec: partitions=1, partition_sizes=[1]

# Same equality chain in a different order.
query TT
EXPLAIN FORMAT INDENT SELECT * FROM t4 WHERE b = c AND a = b AND a > 5;
----
logical_plan
01)Filter: t4.c = t4.b AND t4.b = t4.a AND t4.a > Int32(5)
02)--TableScan: t4 projection=[a, b, c, d]
physical_plan
01)FilterExec: c@2 = b@1 AND b@1 = a@0 AND a@0 > 5 AND a@0 >= 6 AND b@1 >= 6 AND c@2 >= 6
02)--DataSourceExec: partitions=1, partition_sizes=[1]

query TT
EXPLAIN FORMAT INDENT SELECT b FROM tp WHERE a = b AND b > 10;
----
logical_plan
01)Projection: tp.b
02)--Filter: tp.b = tp.a AND tp.b > Int32(10)
03)----TableScan: tp projection=[a, b], partial_filters=[tp.b = tp.a, tp.b > Int32(10)]
physical_plan
01)FilterExec: b@1 = a@0 AND b@1 > 10 AND a@0 >= 11 AND b@1 >= 11, projection=[b@1]
02)--RepartitionExec: partitioning=RoundRobinBatch(4), input_partitions=1
03)----DataSourceExec: file_groups={1 group: [[WORKSPACE_ROOT/datafusion/sqllogictest/test_files/scratch/filter_predicate_inference/t.parquet]]}, projection=[a, b], file_type=parquet, predicate=b@1 = a@0 AND b@1 > 10 AND a@0 >= 11 AND b@1 >= 11, pruning_predicate=b_null_count@1 != row_count@2 AND b_max@0 > 10 AND a_null_count@4 != row_count@2 AND a_max@3 >= 11 AND b_null_count@1 != row_count@2 AND b_max@0 >= 11, required_guarantees=[]

statement ok
set datafusion.execution.parquet.pushdown_filters = true;

query TT
EXPLAIN FORMAT INDENT SELECT b FROM tp WHERE a = b AND b > 10;
----
logical_plan
01)Projection: tp.b
02)--Filter: tp.b = tp.a AND tp.b > Int32(10)
03)----TableScan: tp projection=[a, b], partial_filters=[tp.b = tp.a, tp.b > Int32(10)]
physical_plan DataSourceExec: file_groups={1 group: [[WORKSPACE_ROOT/datafusion/sqllogictest/test_files/scratch/filter_predicate_inference/t.parquet]]}, projection=[b], file_type=parquet, predicate=b@1 = a@0 AND b@1 > 10 AND a@0 >= 11 AND b@1 >= 11, pruning_predicate=b_null_count@1 != row_count@2 AND b_max@0 > 10 AND a_null_count@4 != row_count@2 AND a_max@3 >= 11 AND b_null_count@1 != row_count@2 AND b_max@0 >= 11, required_guarantees=[]

statement ok
reset datafusion.execution.parquet.pushdown_filters;

query TT
EXPLAIN FORMAT INDENT SELECT * FROM t WHERE a > 10 AND a < 5;
----
logical_plan
01)Filter: t.a > Int32(10) AND t.a < Int32(5)
02)--TableScan: t projection=[a, b]
physical_plan EmptyExec

statement ok
reset datafusion.optimizer.enable_filter_predicate_inference;
